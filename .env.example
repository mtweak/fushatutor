# Standard server-side OpenAI API key. Never expose this value to the browser.
OPENAI_API_KEY=

# Current defaults can be overridden without code changes.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REFLECTIVE_MODEL=gpt-5.6-terra
OPENAI_GLOSS_MODEL=gpt-5-mini
OPENAI_REALTIME_VOICE=cedar
OPENAI_TTS_VOICE=cedar

# Optional absolute path; defaults to .data/fusha.db.
FUSHA_DB_PATH=
